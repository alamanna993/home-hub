# Copy this to .env and fill in your values

# Published ports (change if something else on the host already uses them)
#FRONTEND_PORT=3000
#BACKEND_PORT=8000
#DB_PORT=5432

# Database
DB_PASSWORD=changeme_strong_password

# Where Postgres stores its data.
# Default (blank/unset): Docker named volume "postgres_data".
# On a NAS, point it at a host folder instead, e.g.:
#   DATA_PATH=/volume1/docker/homehub/db
#DATA_PATH=

# Automatic database backups (pg_dump with retention).
# Point BACKUP_PATH at a DIFFERENT disk or NAS share than DATA_PATH for real redundancy.
#BACKUP_PATH=./backups
#BACKUP_SCHEDULE=@daily
#BACKUP_KEEP_DAYS=7
#BACKUP_KEEP_WEEKS=4
#BACKUP_KEEP_MONTHS=6

# Auth — generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
DEFAULT_ADMIN_PASSWORD=homehub

# Shared key the bot containers use to talk to the backend API.
# Defaults to SECRET_KEY if left blank.
#INTERNAL_API_KEY=

# Telegram Bot — OPTIONAL here: you can paste the token in the web setup wizard instead.
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Start the stack, message your bot /start — it replies with your chat ID
# 3. Put that ID in TELEGRAM_ALLOWED_CHAT_IDS (comma-separated for multiple people)
#    Leave it blank and the bot will answer anyone who finds it — not recommended.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Discord Bot (optional — start with: docker compose --profile discord up -d)
# 1. Go to https://discord.com/developers/applications → New Application
# 2. Bot tab → Add Bot → copy the Token
# 3. Enable "Message Content Intent" under Privileged Gateway Intents
# 4. Invite the bot to your server with these permissions: Send Messages, Read Message History, Embed Links
# 5. Right-click your inventory channel → Copy Channel ID (enable Developer Mode in Discord settings first)
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# AI Provider: ollama | lmstudio | openai | claude  (default: ollama)
LLM_PROVIDER=ollama

# Ollama (local) — default port 11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# LM Studio (local, OpenAI-compatible) — default port 1234
LMSTUDIO_HOST=http://host.docker.internal:1234
LMSTUDIO_MODEL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
