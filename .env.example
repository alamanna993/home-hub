# Copy this to .env and fill in your values

# Database
DB_PASSWORD=changeme_strong_password

# Auth — generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
DEFAULT_ADMIN_PASSWORD=homehub

# Discord Bot
# 1. Go to https://discord.com/developers/applications → New Application
# 2. Bot tab → Add Bot → copy the Token
# 3. Enable "Message Content Intent" under Privileged Gateway Intents
# 4. Invite the bot to your server with these permissions: Send Messages, Read Message History, Embed Links
# 5. Right-click your inventory channel → Copy Channel ID (enable Developer Mode in Discord settings first)
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Ollama - local LLM
# If Ollama runs on the same Linux/Docker host, use host.docker.internal
# Or set to the IP of your Ollama server e.g. http://192.168.1.100:11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
